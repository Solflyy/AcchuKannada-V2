{
  "expo": {
    "name": "Acchu Kannada",
    "slug": "acchu-kannada-v2",
    "version": "1.3.9",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#8aa88e"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "com.android.vending.BILLING"
      ],
      "versionCode": 16,
      "predictiveBackGestureEnabled": false,
      "edgeToEdgeEnabled": true,
      "package": "com.acchukannada.app",
      "intentFilters": [
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "image/*"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "mimeType": "image/*"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Acchu Kannada to use your camera to take photos.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Acchu Kannada to access your photos to edit them."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Acchu Kannada to save edited photos to your gallery.",
          "savePhotosPermission": "Allow Acchu Kannada to save edited photos to your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "75941a1a-38cb-43ec-aa0e-1a5d49dab0ca"
      }
    }
  }
}
